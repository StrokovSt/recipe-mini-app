{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": false,
        "strict": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        
        "jsx": "react-jsx",
        "typeRoots": ["./node_modules/@types", "./src/types"],
        "paths": {
        "@/*": ["./src/*"]
        }
    },
    "exclude": ["node_modules", "dist"]
}