{
    "eslint.useFlatConfig": true,
    "eslint.nodePath": "node_modules",
    "eslint.validate": [
        "javascript",
        "typescript",
        "javascriptreact",
        "typescriptreact"
    ],
    "eslint.workingDirectories": [
        { "mode": "auto" }
    ],
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "source.fixAll.stylelint": "explicit"
    },
    "stylelint.validate": ["css", "scss"],
    "css.validate": false,
    "scss.validate": false
}